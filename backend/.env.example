# Server Port Configuration
PORT=5000

# PostgreSQL Connection String (e.g. postgresql://user:password@host:port/database?schema=public)
DATABASE_URL="postgresql://postgres:password@localhost:5432/shop_debt_db?schema=public"

# JSON Web Token Configuration
JWT_SECRET="generate-a-secure-random-key-at-least-32-characters"
JWT_EXPIRES_IN="7d"

# Frontend Integration URL
FRONTEND_URL="http://localhost:5173"

# Node Environment (development, production, test)
NODE_ENV="development"
